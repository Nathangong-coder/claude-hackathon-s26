# Get a key from https://console.anthropic.com — required for /api/extract and /api/check-in
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional override (default: claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Twilio — required for SMS medication reminders
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_FROM_NUMBER=+15550000000
# Required for scheduled messages — create a Messaging Service in Twilio console
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
